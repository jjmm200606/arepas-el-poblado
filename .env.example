DATABASE_URL=postgresql://postgres:1234@localhost:5432/arepas_el_poblado
SECRET_KEY=cambia-esta-clave

# Wompi sandbox usa prefijos pub_test_ y test_integrity_.
# Wompi produccion usa prefijos pub_prod_ y prod_integrity_.
WOMPI_PUBLIC_KEY=pub_test_tu_llave_publica
